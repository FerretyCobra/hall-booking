# -------------------------------------------------------------
# General Settings
# -------------------------------------------------------------
# Options: mock, zoom, google
ACTIVE_MEETING_PROVIDER=mock
HALL_SECRET=change-me-dev-secret-not-for-production

# -------------------------------------------------------------
# Zoom Server-to-Server OAuth Credentials
# -------------------------------------------------------------
# Log in to Zoom App Marketplace (https://marketplace.zoom.us/), 
# create a "Server-to-Server OAuth" app, and copy the credentials.
ZOOM_ACCOUNT_ID=your_zoom_account_id_here
ZOOM_CLIENT_ID=your_zoom_client_id_here
ZOOM_CLIENT_SECRET=your_zoom_client_secret_here

# -------------------------------------------------------------
# Google Calendar API / Google Meet Credentials
# -------------------------------------------------------------
# Set up a project in Google Cloud Console, enable the Google Calendar API,
# create an OAuth client ID, and generate a Refresh Token.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# -------------------------------------------------------------
# Email / SMTP Configuration
# -------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@icmr-nitvar.res.in
SMTP_USE_TLS=False
DIRECTOR_EMAIL=director@icmr-nitvar.res.in
